{
	"compilerOptions": {
		// Environment setup & latest features
		"lib": ["ESNext"],
		"target": "ESNext",
		"module": "Preserve",
		"moduleDetection": "force",
		"jsx": "react-jsx",
		"allowJs": false,
		"paths": {
			"@PrismaGenerated/*": [
				"./src/generic-subdomains/persistance/prisma/generated/*"
			],
			"@TestUtils": ["./src/generic-subdomains/utils/testUtils.ts"],
			"GlobalValidator": ["./src/shared-kernel/validators/Global.ts"],
			"@Domains/*": ["./src/domains/*"],
			"@Prisma/*": ["./src/generic-subdomains/persistance/prisma/*"],
			"@DomainError": ["./src/generic-subdomains/utils/domainError.ts"],
			"@AppError": ["./src/generic-subdomains/utils/AppError.ts"],
			"@DatabaseError": ["./src/generic-subdomains/utils/databaseError.ts"],
			"@SetupPlugin": ["./src/generic-subdomains/utils/plugins/setupPlugin.ts"],
			"@GenericSubdomains/*": ["./src/generic-subdomains/*"],
			"@SharedKernel/*": ["./src/shared-kernel/*"],
			"@AuthPlugin": ["./src/generic-subdomains/authentication/Composition.ts"],
			"@ClearDatabase": [
				"./src/generic-subdomains/persistance/prisma/ClearDatabase.ts"
			],

			"@PrismaErrorHandler": [
				"./src/generic-subdomains/persistance/prisma/PrismaErrorHandler.ts"
			],
			"@PrismaClient": [
				"./src/generic-subdomains/persistance/prisma/PrismaClient.ts"
			],
			"tests/*": ["./tests/*"],
			"*": ["./src/*"]
		},

		// Bundler mode
		"moduleResolution": "bundler",
		"allowImportingTsExtensions": true,
		"verbatimModuleSyntax": true,
		"noEmit": true,

		// Best practices
		"strict": true,
		"skipLibCheck": true,
		"noFallthroughCasesInSwitch": true,
		"noUncheckedIndexedAccess": true,
		"noImplicitOverride": true,

		// Some stricter flags (disabled by default)
		"noUnusedLocals": false,
		"noUnusedParameters": false,
		"noPropertyAccessFromIndexSignature": false
	},
	"include": [
		"src/**/*.ts",
		"tests/**/*.ts",
		"prisma.config.ts",
		"eslint.config.ts"
	],
	"exclude": ["node_modules", "src/**/generated/**"]
}
