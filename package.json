{
	"name": "hellopoetryback",
	"main": "Server.ts",
	"type": "module",
	"private": true,
	"devDependencies": {
		"@eslint/js": "^10.0.1",
		"@types/bun": "^1.3.9",
		"@types/jsonwebtoken": "^9.0.10",
		"@types/node": "^25.2.3",
		"@types/pg": "^8.16.0",
		"cloc": "^2.6.0-cloc",
		"dependency-cruiser": "^17.3.8",
		"eslint": "^10.0.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-prettier": "^5.5.5",
		"globals": "^17.3.0",
		"jiti": "^2.6.1",
		"madge": "^8.0.0",
		"prisma": "^7.4.0",
		"tsx": "^4.21.0",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.55.0"
	},
	"scripts": {
		"dev": "cross-env NODE_ENV=development bun --watch src/Server.ts",
		"start": "cross-env NODE_ENV=production bun dist/Server.js",
		"start:dev": "cross-env NODE_ENV=development bun dist/Server.js",
		"build": "bun build src/Server.ts --target bun --outdir dist",
		"test": "bun run test:all",
		"test:all": "cross-env NODE_ENV=test bun test --only-failures --reporter=junit --reporter-outfile=./bun.xml",
		"test:unit": "cross-env NODE_ENV=test bun test --only-failures -t USE-CASE && bun test --only-failures -t POLICY --concurrent",
		"test:integration": "cross-env NODE_ENV=test bun test --only-failures -t INTEGRATION",
		"lint": "eslint . --cache",
		"lint:fix": "eslint . --fix --cache",
		"format": "prettier --check . --cache --log-level silent",
		"format:fix": "prettier --write . --cache --log-level silent",
		"fmt": "bun run format",
		"fmt:fix": "bun run format:fix",
		"typecheck": "tsc --noEmit",
		"check:env:dev": "cross-env NODE_ENV=development bun scripts/check-env.ts",
		"check:env:test": "cross-env NODE_ENV=test bun scripts/check-env.ts",
		"check:env:prod": "cross-env NODE_ENV=production bun scripts/check-env.ts",
		"check:env": "bun run check:env:dev",
		"barrels": "bunx barrelsby -c barrels.config.json",
		"depcruise": "bunx depcruise src",
		"metrics:cloc": "cloc src --by-file --exclude-dir=node_modules,dist,build,coverage,prisma --json --out cloc.json --quiet",
		"metrics:depcruise": "depcruise src --exclude \"node_modules|dist|coverage\" --output-type json --output-to depcruise.json",
		"metrics:analysis": "bun architecture-analysis/src/main.ts",
		"metrics": "bun run metrics:cloc && bun run metrics:depcruise && bun run metrics:analysis",
		"check": "bun run check:env && bun run barrels && bun run lint:fix && bun run format:fix && bun run metrics && bun run depcruise && bun run typecheck && bun run test:unit && bun run build && echo 'All checks passed!'",
		"check:test": "bun run check:env:test && bun run barrels && bun run lint:fix && bun run format:fix && bun run metrics && bun run depcruise && bun run typecheck && bun run test:unit && bun run build && echo 'All checks passed (test)!'",
		"check:prod": "bun run check:env:prod && bun run barrels && bun run lint:fix && bun run format:fix && bun run metrics && bun run depcruise && bun run typecheck && bun run test:unit && bun run build && echo 'All checks passed (prod)!'",
		"generate": "npx prisma generate",
		"migratedev": "npx prisma migrate dev",
		"migrateprod": "npx prisma migrate deploy",
		"seed": "npx prisma db seed",
		"reset": "npx prisma migrate reset --force",
		"drop": "npx prisma db push --force-reset",
		"add-test-data": "bun scripts/add-test-data.ts",
		"create-admin": "bun scripts/create-admin.ts",
		"docker:up": "docker build -t api . && docker run --env-file .env.production -p 5000:5000 api",
		"compose": "docker-compose up --build"
	},
	"dependencies": {
		"cross-env": "^7.0.3",
		"@aws-sdk/client-s3": "^3.1009.0",
		"@aws-sdk/s3-presigned-post": "^3.1009.0",
		"@aws-sdk/s3-request-presigner": "^3.1009.0",
		"@elysiajs/cors": "^1.4.1",
		"@elysiajs/openapi": "^1.4.14",
		"@prisma/adapter-pg": "^7.4.0",
		"@prisma/client": "^7.4.0",
		"barrelsby": "^2.8.1",
		"bcryptjs": "^3.0.3",
		"dotenv": "^17.2.4",
		"elysia": "^1.4.25",
		"elysia-rate-limit": "^4.5.0",
		"jsonwebtoken": "^9.0.3",
		"kleur": "^4.1.5",
		"pino": "^10.3.1",
		"pino-pretty": "^13.1.3",
		"slugify": "^1.6.6",
		"ts-morph": "^27.0.2",
		"xss": "^1.0.15"
	},
	"overrides": {
		"@aws-sdk/client-s3": "^3.1009.0"
	}
}
